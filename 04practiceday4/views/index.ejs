<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
  <div class="main w-full min-h-screen bg-zinc-900 ">

    <div class="form px-10 py-10 text-white">

      <form action="/create" method="post">
        <input class= "block w-full rounded-md outline-none px-5 py-3 bg-zinc-800" type="text" placeholder="Title goes here" name="title"/>
        <textarea  class= "block w-full  rounded-md outline-none mt-2 px-5 py-3 resize-none bg-zinc-800" placeholder="description goes here" name="details"></textarea>
        <input class="mt-2 bg-blue-600 px-5 py-2 rounded-md" type="submit" value="create task"/>
      </form>
    </div>

    <div class = "tasks flex gap-4 flex-wrap p-10">
      <% if (files.length > 0) { %>

  <% files.forEach(function(val) { %>

    <div class="task w-72 px-3 py-4 bg-zinc-800 rounded-md text-white">
      <h2 class="text-3xl tracking-tighter"><%= val %></h2>
      <a href="/file/<%= val %>" class="text-blue-500 hover:text-blue-400">
        Read more..
      </a>
    </div>

  <% }) %>

  <% } else { %>

  <h3 class="text-zinc-400">No task yet.</h3>

  <% } %>
      
    </div>
  </div>
</body>
</html>
