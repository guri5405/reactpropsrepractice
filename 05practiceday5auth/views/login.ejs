<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title>Login page</title>
</head>
<body>
  <div class="w-full h-screen bg-zinc-900 text-white p-10">
    <h1>Login</h1>
    <form method="post" action="/login">
      <input type="email" placeholder="email" name="email" class=" px-3 py-2 rounded-md bg-transparent border-2 border-zinc-700">
      <input type="password" placeholder="enter Password" name="password" class=" px-3 py-2 rounded-md bg-transparent border-2 border-zinc-700">
      
      <input type="submit" value="Login" class="px-5 py-2 rounded-md bg-blue-500 text-white">
    </form>

  </div>
  
</body>
</html>
